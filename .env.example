# Populate these and rename to `.env` to enable Google sign-in + Firestore sync.
# Leave any of the required four blank to run the app in local-only mode
# (localStorage) — the sign-in screen will not be shown.
#
# These identify a Firebase project. They are not secrets: Firebase web API
# keys are public by design and real access control is enforced by
# firestore.rules. If you fork this project, point these at *your own* Firebase
# project — the values below are placeholders, not a working project.

# Required for Firebase to activate
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000000000

# Optional
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional — override the on-device LLM model URL (default: Gemma 4 E2B).
# VITE_LLM_MODEL_URL=https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/main/gemma-4-E2B-it-web.task

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
# But the in-repo Capacitor plugin compiles to dist/ — that has to
# be committed so the `file:./plugins/*` references resolve on a
# fresh checkout / CI run. The exception is below.
!plugins/insight-llm/dist
!plugins/insight-llm/dist/**
!plugins/insight-health/dist
!plugins/insight-health/dist/**
*.local

# Environment variables — copy .env.example to .env and fill in your values
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Capacitor / native build artifacts ────────────────────────────
# The ios/ and android/ project shells are committed so anyone can
# build the apps; their generated build output, dependency caches,
# and IDE state are not.

# Vite output that Capacitor copies into native shells on `cap sync`
ios/App/App/public/
android/app/src/main/assets/public/
ios/App/App/capacitor.config.json
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# iOS build / Pods / IDE state
ios/App/Pods/
ios/App/Podfile.lock
ios/App/build/
ios/DerivedData/
ios/build/
ios/.gradle/
xcuserdata/
*.xcuserstate

# Android build / Gradle cache / IDE state
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/captures/
android/.idea/
android/*.iml
android/app/*.iml


# Plugin node_modules; the compiled dist/ IS committed so the
# `file:./plugins/*` deps resolve on fresh checkouts.
plugins/*/node_modules/

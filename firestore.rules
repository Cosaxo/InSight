rules_version = '2';

// Every user can read and write only their own subtree under
// `insight_users/{uid}`. No unauthenticated access.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /insight_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Discoverable users — anyone signed in can read (so nearby
    // discovery works), but only the owner can write their own doc.
    // The doc holds (fuzzed) location + minimal profile chrome; full
    // personal data still lives under `insight_users/{uid}/`.
    match /insight_discoverable/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Cities catalogue — world cities + their geohash + geopoint.
    // Read-only for any signed-in user (the nearest-city query runs
    // against this collection). Writes are out-of-band (admin tooling).
    match /Cities/{cityId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
